generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  @@map("user_role")
}

enum NotificationType{
  POST_LIKED
  POST_COMMENTED 
  FOLLOWED
  SYSTEM
}

enum NotificationTargetKind{
  post
  comment
  user
  system
}

enum ConversationKind {
  DIRECT
  GROUP
  @@map("conversation_kind")
}

enum StoryMediaType {
  IMAGE
  VIDEO
  TEXT
  @@map("story_media_type")
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
  @@map("reaction_type")
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  VIOLENCE
  NUDITY
  OTHER
  @@map("report_reason")
}

enum ReportTargetKind {
  POST
  COMMENT
  USER
  REEL
  @@map("report_target_kind")
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  @@map("report_status")
}

model User {
  id                   String         @id @db.VarChar(255)
  name                 String         @db.VarChar(255)
  email                String         @unique @db.VarChar(255)
  avatarUrl            String?        @map("avatar_url")
  /** Short public bio / tiểu sử (optional). */
  bio                  String?        @db.Text @map("bio")
  emailVerified        Boolean        @default(false) @map("email_verified")
  role                 UserRole       @default(USER) @map("role")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @default(now()) @map("updated_at")
  /** Last activity ping (socket or POST /me/presence). Used for “online / last seen”. */
  lastSeenAt           DateTime?      @map("last_seen_at")
  accounts             Account[]
  conversationsAsUser1 Conversation[] @relation("User1")
  conversationsAsUser2 Conversation[] @relation("User2")
  messages             Message[]
  notificationsActor   Notification[] @relation("NotificationActor")
  notifications        Notification[] @relation("NotificationUser")
  posts                Post[]
  sessions             Session[]
  postLikes            PostLike[]
  comments             Comment[]
  following            Follow[]       @relation("UserFollowing")
  followers            Follow[]       @relation("UserFollowers")
  conversationMembers     ConversationMember[]
  conversationReadStates ConversationReadState[]
  conversationHides       ConversationHide[]
  stories                 Story[]
  storyViews              StoryView[]
  reels                   Reel[]
  reelLikes               ReelLike[]
  reelViews               ReelView[]
  savedPosts              SavedPost[]
  postReposts             PostRepost[]
  reportsSubmitted        Report[]

  @@map("user")
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  String   @map("follower_id") @db.VarChar(255)
  followingId String   @map("following_id") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId], map: "follows_follower_following_unique")
  @@index([followingId], map: "follows_following_id_idx")
  @@map("follows")
}

model Session {
  id        String   @id @db.VarChar(255)
  userId    String   @map("user_id") @db.VarChar(255)
  token     String   @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  ipAddress String   @map("ip_address") @db.VarChar(255)
  userAgent String   @map("user_agent") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("session")
}

model Account {
  id         String   @id @db.VarChar(255)
  userId     String   @map("user_id") @db.VarChar(255)
  accountId  String   @map("account_id") @db.VarChar(255)
  providerId String   @map("provider_id") @db.VarChar(255)
  password   String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")
  user       User     @relation(fields: [userId], references: [id])

  @@map("account")
}

model Post {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  description  String   @db.VarChar(255)
  slug         String   @db.VarChar(255)
  content      String
  imageUrls    String?  @map("image_urls")
  videoUrls    String?  @map("video_urls")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  shareCount   Int      @default(0) @map("share_count")
  authorId     String   @map("author_id") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  author       User     @relation(fields: [authorId], references: [id])
  likes        PostLike[]
  comments     Comment[]
  savedPosts   SavedPost[]
  reposts      PostRepost[]
  categoryId Int?      @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId], map: "posts_category_id_idx")
  @@map("posts")
}

model PostLike {
  id        Int          @id @default(autoincrement())
  postId    Int          @map("post_id")
  userId    String       @map("user_id") @db.VarChar(255)
  reaction  ReactionType @default(LIKE) @map("reaction")
  createdAt DateTime     @default(now()) @map("created_at")
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "post_likes_post_user_unique")
  @@map("post_likes")
}

model Comment {
  id        Int       @id @default(autoincrement())
  postId    Int       @map("post_id")
  authorId  String    @map("author_id") @db.VarChar(255)
  content   String    @db.Text
  parentId  Int?      @map("parent_id")
  createdAt DateTime  @default(now()) @map("created_at")
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([parentId], map: "comments_parent_id_idx")
  @@map("comments")
}

model Conversation {
  id        Int              @id @default(autoincrement())
  kind      ConversationKind @default(DIRECT) @map("kind")
  title     String?          @map("title") @db.VarChar(255)
  user1Id   String?          @map("user1_id") @db.VarChar(255)
  user2Id   String?          @map("user2_id") @db.VarChar(255)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @default(now()) @map("updated_at")
  user1     User?            @relation("User1", fields: [user1Id], references: [id])
  user2     User?            @relation("User2", fields: [user2Id], references: [id])
  messages   Message[]
  members    ConversationMember[]
  readStates ConversationReadState[]
  hides      ConversationHide[]

  @@map("conversations")
}

/** User hid this conversation from their inbox (others unaffected). */
model ConversationHide {
  id               Int          @id @default(autoincrement())
  userId           String       @map("user_id") @db.VarChar(255)
  conversationId   Int          @map("conversation_id")
  hiddenAt         DateTime     @default(now()) @map("hidden_at")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId], map: "conversation_hides_user_conv_unique")
  @@index([conversationId], map: "conversation_hides_conv_idx")
  @@map("conversation_hides")
}

model ConversationMember {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  userId         String       @map("user_id") @db.VarChar(255)
  joinedAt       DateTime     @default(now()) @map("joined_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId], map: "conversation_members_conv_user_unique")
  @@map("conversation_members")
}

/** Per-user read cursor for a conversation (DIRECT + GROUP). Unread = inbound messages with id > lastReadMessageId. */
model ConversationReadState {
  id                Int      @id @default(autoincrement())
  userId            String   @map("user_id") @db.VarChar(255)
  conversationId    Int      @map("conversation_id")
  lastReadMessageId Int      @default(0) @map("last_read_message_id")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId], map: "conversation_read_state_user_conv_unique")
  @@index([conversationId], map: "conversation_read_state_conv_idx")
  @@map("conversation_read_states")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  senderId       String       @map("sender_id") @db.VarChar(255)
  content        String?
  imageUrl       String?      @map("image_url")
  videoUrl       String?      @map("video_url")
  audioUrl       String?      @map("audio_url")
  audioDurationSec Int?       @map("audio_duration_sec")
  read           Boolean      @default(false)
  revokedAt      DateTime?    @map("revoked_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.VarChar(255)
  actorId   String   @map("actor_id") @db.VarChar(255)
  type      String
  meta      Json     @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  actor     User     @relation("NotificationActor", fields: [actorId], references: [id])
  user      User     @relation("NotificationUser", fields: [userId], references: [id])

  @@map("notifications")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  posts     Post[]

  @@map("categories")
}


model AppNotification {
  id          Int      @id @default(autoincrement())
  recipientId String   @map("recipient_id") @db.VarChar(255)
  // Aggregation fields
  actorIds    Json     @default("[]") @map("actor_ids")   // store string[]
  actorCount  Int      @default(0) @map("actor_count")
  type        NotificationType
  targetKind  NotificationTargetKind @map("target_kind")
  targetId    String   @map("target_id") @db.VarChar(255)
  targetSlug  String?  @map("target_slug") @db.VarChar(255)
  meta        Json     @default("{}")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@index([recipientId, createdAt(sort: Desc)], map: "app_notif_recipient_created_idx")
  @@index([recipientId, readAt, updatedAt(sort: Desc)], map: "app_notif_recipient_read_updated_idx")
  @@index([recipientId, type, targetKind, targetId, readAt], map: "app_notif_agg_lookup_idx")
  @@map("app_notifications")
}
model AppNotificationCounter {
  userId     String   @id @map("user_id") @db.VarChar(255)
  unread     Int      @default(0)
  lastReadAt DateTime? @map("last_read_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@map("app_notification_counters")
}

model Story {
  id              Int            @id @default(autoincrement())
  authorId        String         @map("author_id") @db.VarChar(255)
  mediaType       StoryMediaType @map("media_type")
  imageUrl        String?        @map("image_url")
  videoUrl        String?        @map("video_url")
  textContent     String?        @map("text_content") @db.Text
  backgroundColor String?        @map("background_color") @db.VarChar(32)
  expiresAt       DateTime       @map("expires_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  author          User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views           StoryView[]

  @@index([authorId, expiresAt], map: "stories_author_expires_idx")
  @@index([expiresAt], map: "stories_expires_idx")
  @@map("stories")
}

model StoryView {
  id       Int      @id @default(autoincrement())
  storyId  Int      @map("story_id")
  viewerId String   @map("viewer_id") @db.VarChar(255)
  viewedAt DateTime @default(now()) @map("viewed_at")
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer   User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId], map: "story_views_story_viewer_unique")
  @@index([viewerId], map: "story_views_viewer_idx")
  @@map("story_views")
}

model Reel {
  id           Int      @id @default(autoincrement())
  authorId     String   @map("author_id") @db.VarChar(255)
  videoUrl     String   @map("video_url")
  caption      String?  @db.VarChar(500)
  viewCount    Int      @default(0) @map("view_count")
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  author User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes  ReelLike[]
  views  ReelView[]
  @@index([authorId, createdAt(sort: Desc)], map: "reels_author_created_idx")
  @@index([createdAt(sort: Desc)], map: "reels_created_idx")
  @@map("reels")
}

model ReelLike {
  id        Int          @id @default(autoincrement())
  reelId    Int          @map("reel_id")
  userId    String       @map("user_id") @db.VarChar(255)
  reaction  ReactionType @default(LIKE) @map("reaction")
  createdAt DateTime     @default(now()) @map("created_at")
  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([reelId, userId], map: "reel_likes_reel_user_unique")
  @@map("reel_likes")
}

model ReelView {
  id       Int      @id @default(autoincrement())
  reelId   Int      @map("reel_id")
  viewerId String   @map("viewer_id") @db.VarChar(255)
  viewedAt DateTime @default(now()) @map("viewed_at")
  reel   Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  viewer User @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  @@unique([reelId, viewerId], map: "reel_views_reel_viewer_unique")
  @@index([viewerId], map: "reel_views_viewer_idx")
  @@map("reel_views")
}

model SavedPost {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.VarChar(255)
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], map: "saved_posts_user_post_unique")
  @@index([userId, createdAt(sort: Desc)], map: "saved_posts_user_created_idx")
  @@map("saved_posts")
}

model PostRepost {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.VarChar(255)
  postId    Int      @map("post_id")
  caption   String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], map: "post_reposts_user_post_unique")
  @@index([userId, createdAt(sort: Desc)], map: "post_reposts_user_created_idx")
  @@index([postId], map: "post_reposts_post_idx")
  @@map("post_reposts")
}

model Report {
  id         Int              @id @default(autoincrement())
  reporterId String           @map("reporter_id") @db.VarChar(255)
  targetKind ReportTargetKind @map("target_kind")
  targetId   String           @map("target_id") @db.VarChar(255)
  reason     ReportReason
  details    String?          @db.VarChar(1000)
  status     ReportStatus     @default(PENDING)
  createdAt  DateTime         @default(now()) @map("created_at")
  reviewedAt DateTime?        @map("reviewed_at")

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetKind, targetId], map: "reports_reporter_target_unique")
  @@index([status, createdAt(sort: Desc)], map: "reports_status_created_idx")
  @@map("reports")
}